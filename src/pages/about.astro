---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

const title = "Über mich - Dennis Heinz";
const description =
  "Dennis Heinz, Softwareentwickler aus dem Münsterland. Backend mit PHP (Mezzio/Laminas), Android (Kotlin/Compose) und Frontend (React/TypeScript). Aktuell bei CHECK24 an Hotel-Middleware.";
---

<Base title={title} description={description}>
  <div class="max-w-2xl mx-auto px-6">
    <Nav />

    <article>
      <header class="pb-10 border-b border-border mb-0">
        <p
          class="text-[12px] tracking-[0.1em] uppercase text-muted-foreground mb-5"
        >
          Über mich
        </p>
        <h1
          class="text-[clamp(2.2rem,5vw,3.4rem)] font-medium leading-[1.1] text-foreground"
        >
          Hi, ich bin Dennis.
        </h1>
      </header>

      <section class="py-6 border-b border-border">
        <p
          class="text-[15px] text-muted-foreground leading-[1.75] max-w-[60ch]"
        >
          Ich bin Softwareentwickler aus dem Münsterland in Deutschland. Diese
          Seite ist mein Platz im Netz - für Notizen, Projekte und das, woran
          ich gerade arbeite.
        </p>
      </section>

      <section class="py-6 border-b border-border">
        <h2 class="text-sm font-medium text-foreground mb-3 tracking-[0.04em]">
          Was ich beruflich mache
        </h2>
        <p
          class="text-[15px] text-muted-foreground leading-[1.75] max-w-[60ch]"
        >
          Mein Schwerpunkt liegt im Backend, vor allem mit PHP - Mezzio und
          Laminas. Daneben arbeite ich mit Android (Kotlin und Jetpack Compose)
          und im Frontend mit React und TypeScript. Aktuell bin ich bei CHECK24
          und kümmere mich dort um Hotel-Middleware und BFF-Infrastruktur.
        </p>
      </section>

      <section class="py-6 border-b border-border">
        <h2 class="text-sm font-medium text-foreground mb-3 tracking-[0.04em]">
          Nebenprojekte
        </h2>
        <p
          class="text-[15px] text-muted-foreground leading-[1.75] max-w-[60ch]"
        >
          Mein größtes laufendes Projekt heißt <strong
            class="text-foreground font-medium">Lumina</strong
          >: ein räumliches Canvas als persönlicher Intelligenz-Workspace, das
          KI-Agenten, mobile Capture-Flows und einen Laravel/React-Stack
          zusammenbringt. Daneben experimentiere ich mit einer Android-App rund
          um persönliches Wachstum.
        </p>
      </section>

      <section class="py-6 border-b border-border">
        <h2 class="text-sm font-medium text-foreground mb-3 tracking-[0.04em]">
          Abseits vom Code
        </h2>
        <p
          class="text-[15px] text-muted-foreground leading-[1.75] max-w-[60ch]"
        >
          Ich wandere sehr gerne. Aktuell trainiere ich auf die Zugspitze hin.
          Mich interessieren außerdem Investieren (ETFs und Einzelaktien),
          Unternehmertum und alles rund um persönliche Entwicklung.
        </p>
      </section>

      <section class="py-6 border-b border-border">
        <h2 class="text-sm font-medium text-foreground mb-3 tracking-[0.04em]">
          Wohin es gehen soll
        </h2>
        <p
          class="text-[15px] text-muted-foreground leading-[1.75] max-w-[60ch]"
        >
          Auf längere Sicht möchte ich mich Schritt für Schritt in Richtung
          Entrepreneurship bewegen. Diese Seite ist ein Teil davon: ein Ort, an
          dem ich öffentlich denke und das festhalte, was ich auf dem Weg
          dorthin lerne.
        </p>
      </section>

      <section class="py-6">
        <h2 class="text-sm font-medium text-foreground mb-3 tracking-[0.04em]">
          Kontakt
        </h2>
        <p
          class="text-[15px] text-muted-foreground leading-[1.75] max-w-[60ch]"
        >
          Am einfachsten erreichst du mich über{" "}
          <a
            href="https://www.linkedin.com/in/dennis-heinz-a185241a9/"
            class="text-foreground underline underline-offset-[3px] decoration-border hover:decoration-foreground transition-colors"
            >LinkedIn</a
          > oder{" "}
          <a
            href="https://github.com/Dennis-H1"
            class="text-foreground underline underline-offset-[3px] decoration-border hover:decoration-foreground transition-colors"
            >GitHub</a
          >.
        </p>
      </section>
    </article>

    <Footer />
  </div>
</Base>
