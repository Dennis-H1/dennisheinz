---
import { render } from "astro:content";
import Base from "@/layouts/Base.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";
import Tag from "@/components/ui/Tag.astro";
import { strings } from "@/i18n/strings";
import { getPosts, slugOf, findAlternate } from "@/lib/blog";

export async function getStaticPaths() {
  const posts = await getPosts("de");
  return posts.map((post) => ({
    params: { slug: slugOf(post) },
    props: { post },
  }));
}

const lang = "de" as const;
const t = strings[lang];
const { post } = Astro.props;
const { Content } = await render(post);

const alt = await findAlternate(post, "en");
const alternates = {
  de: `${t.routes.blog}${slugOf(post)}/`,
  en: alt ? `${strings.en.routes.blog}${slugOf(alt)}/` : strings.en.routes.blog,
};

const formattedDate = post.data.pubDate.toLocaleDateString("de-DE", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const wordCount = (post.body ?? post.data.description).split(/\s+/).length;
const readTime = Math.max(1, Math.round(wordCount / 200));
---

<Base
  title={post.data.title}
  description={post.data.description}
  ogType="article"
  lang={lang}
>
  <div class="max-w-4xl mx-auto px-6">
    <Nav lang={lang} alternates={alternates} />

    <article>
      <header class="pt-4 pb-10" data-reveal data-reveal-stagger>
        <a href={t.routes.blog} class="post-back">← Blog</a>

        <div class="flex flex-wrap items-center gap-3 mb-5 mt-8">
          {post.data.tag && <Tag size="sm">{post.data.tag}</Tag>}
          <time
            datetime={post.data.pubDate.toISOString()}
            class="text-[11px] font-mono tracking-wider uppercase text-muted-foreground tabular-nums"
            >{formattedDate}</time
          >
          <span class="text-[11px] text-muted-foreground" aria-hidden="true"
            >·</span
          >
          <span class="text-[11px] text-muted-foreground tabular-nums"
            >{t.writing.readTime(readTime)}</span
          >
        </div>

        <h1 class="post-heading max-w-[760px] tracking-tight">
          {post.data.title}
        </h1>

        <p
          class="mt-6 text-lg md:text-xl text-muted-foreground leading-[1.55] max-w-[62ch]"
        >
          {post.data.description}
        </p>
      </header>

      <div
        class="prose prose-neutral dark:prose-invert max-w-[72ch] py-10 border-t border-border post-prose"
        data-reveal
      >
        <Content />
      </div>

      <footer
        class="border-t border-border py-10 flex justify-between text-[13px]"
      >
        <a href={t.routes.blog} class="post-back">← Alle Beiträge</a>
        <a href={t.routes.home} class="post-back">Zurück nach Hause →</a>
      </footer>
    </article>

    <Footer lang={lang} />
  </div>

  <style>
    .post-heading {
      font-size: clamp(2.1rem, 6vw, 3.4rem);
      font-weight: 500;
      line-height: 1.1;
      color: var(--foreground-strong);
    }
    .post-back {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 12px;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--muted-foreground);
      text-decoration: none;
      transition: color 0.2s ease;
    }
    .post-back:hover {
      color: var(--foreground);
    }
    .post-prose :global(h2) {
      font-size: 1.5rem;
      font-weight: 500;
      letter-spacing: -0.01em;
      margin-top: 2.5em;
      margin-bottom: 0.75em;
      color: var(--foreground-strong);
    }
    .post-prose :global(h3) {
      font-size: 1.15rem;
      font-weight: 500;
      margin-top: 2em;
      color: var(--foreground-strong);
    }
    .post-prose :global(p) {
      font-size: 1.0625rem;
      line-height: 1.75;
    }
    .post-prose :global(a) {
      color: var(--primary);
      text-decoration: underline;
      text-underline-offset: 3px;
      text-decoration-thickness: 1px;
      text-decoration-color: color-mix(
        in oklch,
        var(--primary) 45%,
        transparent
      );
      transition:
        color 0.2s ease,
        text-decoration-color 0.2s ease;
    }
    .post-prose :global(a:hover) {
      text-decoration-color: var(--primary);
    }
    .post-prose :global(code) {
      font-size: 0.9em;
      padding: 0.15em 0.35em;
      border-radius: 4px;
      background: var(--muted);
      border: 1px solid var(--border);
    }
    .post-prose :global(pre code) {
      padding: 0;
      background: transparent;
      border: 0;
    }
    .post-prose :global(pre) {
      border: 1px solid var(--border);
      border-radius: 8px;
    }
    .post-prose :global(blockquote) {
      border-left: 2px solid var(--border);
      padding-left: 1.25rem;
      font-style: normal;
      color: var(--foreground);
    }
  </style>

  <script>
    import { initReveal } from "@/scripts/reveal";
    initReveal();
  </script>
</Base>
