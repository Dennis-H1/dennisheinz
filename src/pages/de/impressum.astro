---
import Base from "@/layouts/Base.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";
import SectionLabel from "@/components/ui/SectionLabel.astro";
import { strings } from "@/i18n/strings";

const lang = "de" as const;
const t = strings[lang];

const title = `${t.legal.title} — Dennis Heinz`;

const alternates = { de: t.routes.legal, en: strings.en.routes.legal };
---

<Base title={title} description={t.legal.description} lang={lang}>
  <div class="max-w-4xl mx-auto px-6">
    <Nav lang={lang} alternates={alternates} />

    <article>
      <header class="pt-4 pb-10 md:pb-12" data-reveal data-reveal-stagger>
        <SectionLabel class="mb-6">{t.legal.eyebrow}</SectionLabel>
        <h1 class="legal-heading mb-6 tracking-tight">{t.legal.title}</h1>
        <p
          class="text-lg md:text-xl text-muted-foreground leading-[1.55] max-w-[60ch]"
        >
          {t.legal.description}
        </p>
      </header>

      <section class="legal-block" data-reveal>
        <SectionLabel as="h2" class="mb-6"
          >{t.legal.headings.identity}</SectionLabel
        >
        <dl class="legal-dl">
          <dt>{t.legal.labels.name}</dt>
          <dd>Dennis Heinz</dd>
          <dt>{t.legal.labels.address}</dt>
          <dd>
            Eltropweg 30<br />
            48155 Münster<br />
            Deutschland
          </dd>
        </dl>
      </section>

      <section class="legal-block" data-reveal>
        <SectionLabel as="h2" class="mb-6"
          >{t.legal.headings.contact}</SectionLabel
        >
        <dl class="legal-dl">
          <dt>{t.legal.labels.phone}</dt>
          <dd>
            <a href="tel:+4916367860680" class="link">+49 (0) 163 / 678 60 68</a
            >
          </dd>
          <dt>{t.legal.labels.email}</dt>
          <dd>
            <a href="mailto:dennis@dennisheinz.com" class="link"
              >&#100;ennis&#64;&#100;ennisheinz&#46;com</a
            >
          </dd>
        </dl>
      </section>

      <section class="legal-block" data-reveal>
        <SectionLabel as="h2" class="mb-6"
          >{t.legal.headings.responsible}</SectionLabel
        >
        <dl class="legal-dl">
          <dt>{t.legal.labels.name}</dt>
          <dd>Dennis Heinz</dd>
          <dt>{t.legal.labels.address}</dt>
          <dd>
            Eltropweg 30<br />
            48155 Münster<br />
            Deutschland
          </dd>
        </dl>
        <p class="legal-note">{t.legal.note}</p>
      </section>
    </article>

    <Footer lang={lang} />
  </div>

  <style>
    .legal-heading {
      font-size: clamp(2rem, 6vw, 3.5rem);
      font-weight: 500;
      line-height: 1.08;
      color: var(--foreground-strong);
    }
    .legal-block {
      padding: 2.5rem 0;
      border-top: 1px solid var(--border);
    }
    @media (min-width: 768px) {
      .legal-block {
        padding: 3rem 0;
      }
    }
    .legal-dl {
      display: grid;
      grid-template-columns: 9rem 1fr;
      gap: 0.85rem 1.5rem;
      font-size: 15px;
      line-height: 1.65;
    }
    @media (max-width: 640px) {
      .legal-dl {
        grid-template-columns: 1fr;
        gap: 0.25rem 0;
      }
    }
    .legal-dl dt {
      font-size: 12px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--muted-foreground);
      padding-top: 2px;
    }
    @media (max-width: 640px) {
      .legal-dl dt {
        padding-top: 1.25rem;
      }
      .legal-dl dt:first-of-type {
        padding-top: 0;
      }
    }
    .legal-dl dd {
      color: var(--foreground);
      margin: 0;
    }
    .legal-note {
      margin-top: 1.5rem;
      font-size: 13px;
      color: var(--muted-foreground);
    }
  </style>

  <script>
    import { initReveal } from "@/scripts/reveal";
    initReveal();
  </script>
</Base>
