---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { getCollection } from "astro:content";

const title = "Blog - Dennis Heinz";
const description =
  "Notizen von Dennis Heinz über Software, Nebenprojekte und die Dinge, die ich gerade herausfinde.";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
---

<Base title={title} description={description}>
  <div class="max-w-2xl mx-auto px-6">
    <Nav />

    <header class="pb-10 border-b border-border mb-8">
      <p class="text-[12px] tracking-[0.1em] uppercase text-muted-foreground mb-6">Blog</p>
      <h1 class="text-[clamp(2.2rem,5vw,3.4rem)] font-medium leading-[1.1] text-foreground mb-6">
        Notizen
      </h1>
      <p class="text-base text-muted-foreground leading-[1.7] max-w-[480px]">
        Gedanken zu Software, Nebenprojekten und dem, was ich gerade lerne.
      </p>
    </header>

    <section class="py-8">
      {
        posts.length === 0 ? (
          <p class="text-sm text-muted-foreground leading-[1.7]">
            Hier ist noch nichts. Die ersten Beiträge sind in Arbeit.
            Zwischenzeitlich findest du mich auf{" "}
            <a
              href="https://github.com/Dennis-H1"
              class="text-foreground underline underline-offset-[3px] decoration-border hover:decoration-foreground transition-colors"
            >
              GitHub
            </a>
            .
          </p>
        ) : (
          <div class="flex flex-col">
            {posts.map((post) => (
              <a
                href={`/blog/${post.id}/`}
                class="flex items-center justify-between py-4 border-t border-border text-muted-foreground hover:text-foreground transition-colors no-underline"
              >
                <span class="text-[15px] font-medium">{post.data.title}</span>
                <div class="flex items-center gap-4">
                  <span class="text-[11px]">{post.data.pubDate.toLocaleDateString("de-DE")}</span>
                  <span class="text-sm">→</span>
                </div>
              </a>
            ))}
          </div>
        )
      }
    </section>

    <Footer />
  </div>
</Base>
