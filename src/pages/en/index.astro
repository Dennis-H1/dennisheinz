---
import Layout from "../../layouts/Layout.astro";

const description =
  "Dennis Heinz – software developer based near Münster, Germany. Writing about software, side projects, and the things I'm figuring out.";
---

<Layout title="Dennis Heinz – Software Developer" description={description}>
  <div class="site">
    <nav class="nav">
      <a href="/en/" class="nav-logo">Dennis Heinz</a>
      <div class="nav-links">
        <a href="/en/about">About</a>
        <a href="/en/blog">Blog</a>
      </div>
    </nav>

    <section class="hero">
      <p class="hero-label">Software developer · Münsterland, DE</p>
      <h1 class="hero-title">Dennis Heinz</h1>
      <p class="hero-sub">
        Developer. Builder. Writing about software, side projects, and the
        things I'm figuring out.
      </p>
    </section>

    <div class="section">
      <p class="section-label" style="margin-bottom: 1.25rem;">Find me at</p>
      <div class="list">
        <a class="list-item" href="/en/about">
          <span class="list-name">About</span>
          <span class="list-arrow">→</span>
        </a>
        <a class="list-item" href="/en/blog">
          <span class="list-name">Blog</span>
          <span class="list-arrow">→</span>
        </a>
      </div>
    </div>

    <footer class="footer">
      <span>© 2026 Dennis Heinz</span>
      <div>
        <a href="/impressum">Impressum</a>
        <a href="https://github.com/Dennis-H1" rel="me">GitHub</a>
        <a href="https://www.linkedin.com/in/dennis-heinz-a185241a9/" rel="me"
          >LinkedIn</a
        >
      </div>
    </footer>
  </div>
</Layout>
