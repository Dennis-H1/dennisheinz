---
import Base from "@/layouts/Base.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";
import SectionLabel from "@/components/ui/SectionLabel.astro";
import { strings } from "@/i18n/strings";

const lang = "en" as const;
const t = strings[lang];

const alternates = { de: strings.de.routes.home, en: t.routes.home };
---

<Base
  title={`${t.notFound.title} — Dennis Heinz`}
  description={t.notFound.body}
  lang={lang}
>
  <div class="max-w-2xl mx-auto px-6">
    <Nav lang={lang} alternates={alternates} />

    <main class="py-16">
      <SectionLabel class="mb-5">{t.notFound.eyebrow}</SectionLabel>
      <h1 class="not-found-heading mb-4 tracking-tight">{t.notFound.title}</h1>
      <p class="text-muted-foreground mb-8 max-w-[55ch] leading-relaxed">
        {t.notFound.body}
      </p>
      <a
        href={t.routes.home}
        class="text-[15px] font-medium text-muted-foreground hover:text-foreground transition-colors no-underline"
      >
        {t.notFound.home}
      </a>
    </main>

    <Footer lang={lang} />
  </div>

  <style>
    .not-found-heading {
      font-size: clamp(2rem, 6vw, 3rem);
      font-weight: 500;
      line-height: 1.08;
      color: var(--foreground-strong);
    }
  </style>
</Base>
