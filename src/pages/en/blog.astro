---
import Layout from "../../layouts/Layout.astro";

const title = "Blog - Dennis Heinz";
const description =
  "Notes from Dennis Heinz on software, side projects, and the things I'm figuring out.";

const posts: { title: string; slug: string; date: string; excerpt: string }[] =
  [];
---

<Layout title={title} description={description}>
  <div class="site">
    <nav class="nav">
      <a href="/en/" class="nav-logo">Dennis Heinz</a>
      <div class="nav-links">
        <a href="/en/about">About</a>
        <a href="/en/blog">Blog</a>
      </div>
    </nav>

    <header class="prose-header">
      <p class="hero-label">Blog</p>
      <h1 class="hero-title">Notes</h1>
      <p class="hero-sub">
        Thoughts on software, side projects, and what I'm currently learning.
      </p>
    </header>

    <section class="section">
      {
        posts.length === 0 ? (
          <p class="empty">
            Nothing here yet. First posts are on the way. In the meantime you
            can find me on <a href="https://github.com/Dennis-H1">GitHub</a>.
          </p>
        ) : (
          <div class="list">
            {posts.map((post) => (
              <a class="list-item" href={`/en/blog/${post.slug}`}>
                <span class="list-name">{post.title}</span>
                <div class="list-meta">
                  <span class="list-tag">{post.date}</span>
                  <span class="list-arrow">→</span>
                </div>
              </a>
            ))}
          </div>
        )
      }
    </section>

    <footer class="footer">
      <span>© 2026 Dennis Heinz</span>
      <div>
        <a href="/impressum">Impressum</a>
        <a href="https://github.com/Dennis-H1" rel="me">GitHub</a>
        <a href="https://www.linkedin.com/in/dennis-heinz-a185241a9/" rel="me"
          >LinkedIn</a
        >
      </div>
    </footer>
  </div>
</Layout>
