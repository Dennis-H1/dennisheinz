---
import Layout from "../../layouts/Layout.astro";

const title = "About - Dennis Heinz";
const description =
  "Dennis Heinz, software developer based near Münster, Germany. Backend in PHP (Mezzio/Laminas), Android (Kotlin/Compose), and frontend (React/TypeScript). Currently at CHECK24 working on hotel middleware.";
---

<Layout title={title} description={description}>
  <div class="site">
    <nav class="nav">
      <a href="/en/" class="nav-logo">Dennis Heinz</a>
      <div class="nav-links">
        <a href="/en/about">About</a>
        <a href="/en/blog">Blog</a>
      </div>
    </nav>

    <article class="prose">
      <header class="prose-header">
        <p class="hero-label">About</p>
        <h1 class="hero-title">Hi, I'm Dennis.</h1>
      </header>

      <section>
        <p>
          I'm a software developer based near Münster, Germany. This site is my
          corner of the web - a place for notes, projects, and the things I'm
          currently working on.
        </p>
      </section>

      <section>
        <h2>What I do for work</h2>
        <p>
          My background is backend-heavy, mostly in PHP - Mezzio and Laminas.
          Alongside that I work with Android (Kotlin and Jetpack Compose) and on
          the frontend with React and TypeScript. Right now I'm at CHECK24,
          working on hotel middleware and BFF infrastructure.
        </p>
      </section>

      <section>
        <h2>Side projects</h2>
        <p>
          My main side project is <strong>Lumina</strong> - a spatial canvas personal
          intelligence workspace that brings together AI agents, mobile capture, and
          a Laravel/React stack. I'm also exploring an Android app focused on personal
          growth.
        </p>
      </section>

      <section>
        <h2>Outside of code</h2>
        <p>
          I hike - I'm currently training toward the Zugspitze. Beyond that, I
          spend time on investing (ETFs and individual stocks),
          entrepreneurship, and personal development.
        </p>
      </section>

      <section>
        <h2>Where this is going</h2>
        <p>
          Longer term, I'm gradually shifting toward entrepreneurship and
          independent work. This site is part of that: a place to think in
          public and keep track of what I learn along the way.
        </p>
      </section>

      <section>
        <h2>Get in touch</h2>
        <p>
          The easiest way to reach me is via
          <a href="https://www.linkedin.com/in/dennis-heinz-a185241a9/"
            >LinkedIn</a
          > or
          <a href="https://github.com/Dennis-H1">GitHub</a>.
        </p>
      </section>
    </article>

    <footer class="footer">
      <span>© 2026 Dennis Heinz</span>
      <div>
        <a href="/impressum">Impressum</a>
        <a href="https://github.com/Dennis-H1" rel="me">GitHub</a>
        <a href="https://www.linkedin.com/in/dennis-heinz-a185241a9/" rel="me"
          >LinkedIn</a
        >
      </div>
    </footer>
  </div>
</Layout>
