---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Hero from "../components/sections/Hero.astro";

const description =
  "Dennis Heinz – Softwareentwickler aus dem Münsterland. Ich schreibe über Software, Nebenprojekte und die Dinge, die ich gerade herausfinde.";
---

<Base title="Dennis Heinz – Softwareentwickler" description={description}>
  <div class="max-w-2xl mx-auto px-6">
    <Nav />

    <Hero />

    <div class="py-8 border-b border-border">
      <p class="text-[11px] tracking-[0.1em] uppercase text-muted-foreground mb-5">
        Hier entlang
      </p>
      <div class="flex flex-col">
        <a
          href="/about/"
          class="flex items-center justify-between py-4 border-t border-border text-muted-foreground hover:text-foreground transition-colors no-underline"
        >
          <span class="text-[15px] font-medium">Über mich</span>
          <span class="text-sm">→</span>
        </a>
        <a
          href="/blog/"
          class="flex items-center justify-between py-4 border-t border-border text-muted-foreground hover:text-foreground transition-colors no-underline"
        >
          <span class="text-[15px] font-medium">Blog</span>
          <span class="text-sm">→</span>
        </a>
      </div>
    </div>

    <Footer />
  </div>
</Base>
