---
import Layout from "../layouts/Layout.astro";

const title = "Impressum - Dennis Heinz";
const description =
  "Impressum und Anbieterkennzeichnung gemäß § 5 DDG für dennisheinz.com.";
---

<Layout title={title} description={description}>
  <div class="site">
    <nav class="nav">
      <a href="/" class="nav-logo">Dennis Heinz</a>
      <div class="nav-links">
        <a href="/about/">Über</a>
        <a href="/blog/">Blog</a>
      </div>
    </nav>

    <article class="prose impressum">
      <header class="prose-header">
        <p class="hero-label">Rechtliches</p>
        <h1 class="hero-title">Impressum</h1>
      </header>

      <section>
        <h2>Angaben gemäß § 5 DDG</h2>
        <dl class="legal-fields">
          <dt>Name</dt>
          <dd>Dennis Heinz</dd>
          <dt>Anschrift</dt>
          <dd>
            Eltropweg 30<br />
            48155 Münster<br />
            Deutschland
          </dd>
        </dl>
      </section>

      <section>
        <h2>Kontakt</h2>
        <dl class="legal-fields">
          <dt>Telefon</dt>
          <dd>
            <a href="tel:+4916367860680">+49 (0) 163 / 678 60 68</a>
          </dd>
          <dt>E-Mail</dt>
          <dd>
            <a href="mailto:dennis@dennisheinz.com"
              >&#100;ennis&#64;&#100;ennisheinz&#46;com</a
            >
          </dd>
        </dl>
      </section>

      <section>
        <h2>Verantwortlich für den Inhalt nach § 18 Abs. 2 MStV</h2>
        <dl class="legal-fields">
          <dt>Name</dt>
          <dd>Dennis Heinz</dd>
          <dt>Anschrift</dt>
          <dd>
            Eltropweg 30<br />
            48155 Münster<br />
            Deutschland
          </dd>
        </dl>
      </section>
    </article>

    <footer class="footer">
      <span>© 2026 Dennis Heinz</span>
      <div>
        <a href="/impressum/">Impressum</a>
        <a href="/datenschutz/">Datenschutz</a>
        <a href="https://github.com/Dennis-H1" rel="me">GitHub</a>
        <a href="https://www.linkedin.com/in/dennis-heinz-a185241a9/" rel="me"
          >LinkedIn</a
        >
      </div>
    </footer>
  </div>
</Layout>

<style>
  .impressum :global(section) {
    padding: 2rem 0;
  }

  .impressum :global(h2) {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    margin-bottom: 1.25rem;
  }

  .legal-fields {
    display: grid;
    grid-template-columns: 8rem 1fr;
    column-gap: 1.5rem;
    row-gap: 0.85rem;
    font-size: 15px;
    line-height: 1.65;
  }

  .legal-fields dt {
    color: var(--color-text-tertiary);
    font-size: 13px;
    padding-top: 2px;
  }

  .legal-fields dd {
    color: var(--color-text-primary);
  }

  .legal-fields dd a {
    color: var(--color-text-primary);
    text-decoration: underline;
    text-decoration-color: var(--color-border-secondary);
    text-underline-offset: 3px;
  }

  .legal-fields dd a:hover {
    text-decoration-color: var(--color-text-primary);
  }

  @media (max-width: 480px) {
    .legal-fields {
      grid-template-columns: 1fr;
      row-gap: 0.25rem;
    }
    .legal-fields dt {
      padding-top: 0.75rem;
    }
    .legal-fields dt:first-of-type {
      padding-top: 0;
    }
  }
</style>
