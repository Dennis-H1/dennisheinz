---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

const title = "Impressum - Dennis Heinz";
const description =
  "Impressum und Anbieterkennzeichnung gemäß § 5 DDG für dennisheinz.com.";
---

<Base title={title} description={description}>
  <div class="max-w-2xl mx-auto px-6">
    <Nav />

    <article>
      <header class="pb-10">
        <p
          class="text-[12px] tracking-[0.1em] uppercase text-muted-foreground mb-5"
        >
          Rechtliches
        </p>
        <h1
          class="text-[clamp(2.2rem,5vw,3.4rem)] font-medium leading-[1.1] text-foreground"
        >
          Impressum
        </h1>
      </header>

      <section class="py-8">
        <h2
          class="text-[11px] font-medium tracking-[0.1em] uppercase text-muted-foreground mb-5"
        >
          Angaben gemäß § 5 DDG
        </h2>
        <dl
          class="grid grid-cols-[8rem_1fr] gap-x-6 gap-y-3 text-[15px] leading-[1.65] max-sm:grid-cols-1"
        >
          <dt class="text-[13px] text-muted-foreground pt-[2px] max-sm:pt-3">
            Name
          </dt>
          <dd class="text-foreground">Dennis Heinz</dd>
          <dt class="text-[13px] text-muted-foreground pt-[2px] max-sm:pt-3">
            Anschrift
          </dt>
          <dd class="text-foreground">
            Eltropweg 30<br />
            48155 Münster<br />
            Deutschland
          </dd>
        </dl>
      </section>

      <section class="py-8">
        <h2
          class="text-[11px] font-medium tracking-[0.1em] uppercase text-muted-foreground mb-5"
        >
          Kontakt
        </h2>
        <dl
          class="grid grid-cols-[8rem_1fr] gap-x-6 gap-y-3 text-[15px] leading-[1.65] max-sm:grid-cols-1"
        >
          <dt class="text-[13px] text-muted-foreground pt-[2px] max-sm:pt-3">
            Telefon
          </dt>
          <dd class="text-foreground">
            <a
              href="tel:+4916367860680"
              class="underline underline-offset-[3px] decoration-border hover:decoration-foreground transition-colors"
            >
              +49 (0) 163 / 678 60 68
            </a>
          </dd>
          <dt class="text-[13px] text-muted-foreground pt-[2px] max-sm:pt-3">
            E-Mail
          </dt>
          <dd class="text-foreground">
            <a
              href="mailto:dennis@dennisheinz.com"
              class="underline underline-offset-[3px] decoration-border hover:decoration-foreground transition-colors"
            >
              &#100;ennis&#64;&#100;ennisheinz&#46;com
            </a>
          </dd>
        </dl>
      </section>

      <section class="py-8">
        <h2
          class="text-[11px] font-medium tracking-[0.1em] uppercase text-muted-foreground mb-5"
        >
          Verantwortlich für den Inhalt nach § 18 Abs. 2 MStV
        </h2>
        <dl
          class="grid grid-cols-[8rem_1fr] gap-x-6 gap-y-3 text-[15px] leading-[1.65] max-sm:grid-cols-1"
        >
          <dt class="text-[13px] text-muted-foreground pt-[2px] max-sm:pt-3">
            Name
          </dt>
          <dd class="text-foreground">Dennis Heinz</dd>
          <dt class="text-[13px] text-muted-foreground pt-[2px] max-sm:pt-3">
            Anschrift
          </dt>
          <dd class="text-foreground">
            Eltropweg 30<br />
            48155 Münster<br />
            Deutschland
          </dd>
        </dl>
      </section>
    </article>

    <Footer />
  </div>
</Base>
