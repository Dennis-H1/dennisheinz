---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: "website" | "article";
}

const {
  title,
  description,
  ogImage,
  ogImageAlt,
  ogType = "website",
} = Astro.props;

const currentLocale = "de" as const;

const canonical = new URL(Astro.url.pathname, Astro.site);

const siteUrl = Astro.site!.toString().replace(/\/$/, "");
const personId = `${siteUrl}/#person`;
const serviceId = `${siteUrl}/#service`;
const websiteId = `${siteUrl}/#website`;
const ogImageId = `${siteUrl}/og/${currentLocale}.png#image`;

const personDescription =
  "Hi, ich bin Dennis, Softwareentwickler aus dem Münsterland. Ich entwickle leidenschaftlich gerne Webanwendungen mit PHP, React und TypeScript und beschäftige mich nebenbei mit Machine Learning. Auf dieser Seite stelle ich meine Projekte vor – schreib mir gerne über LinkedIn oder per E-Mail.";

const serviceDescription =
  "Webentwicklung mit PHP, React, TypeScript und Datenbanken (SQL & NoSQL). Full-Stack von Frontend bis Backend.";

const metaDescription = description ?? personDescription;
const ogImageUrl = new URL(ogImage ?? `/og/${currentLocale}.png`, Astro.site);
const ogImageAltText =
  ogImageAlt ?? "Dennis Heinz – Softwareentwickler aus dem Münsterland";
const siteName = "Dennis Heinz";

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": websiteId,
      url: siteUrl,
      name: siteName,
      description: personDescription,
      inLanguage: currentLocale,
      publisher: { "@id": personId },
    },
    {
      "@type": "ImageObject",
      "@id": ogImageId,
      url: ogImageUrl.toString(),
      contentUrl: ogImageUrl.toString(),
      width: 1200,
      height: 630,
      encodingFormat: "image/png",
      caption: ogImageAltText,
    },
    {
      "@type": "Person",
      "@id": personId,
      name: "Dennis Heinz",
      jobTitle: "Softwareentwickler",
      description: personDescription,
      url: siteUrl,
      image: { "@id": ogImageId },
      email: "mailto:dennis@dennisheinz.com",
      workLocation: [
        { "@type": "Place", name: "Rheine, Deutschland" },
        { "@type": "Place", name: "Münster, Deutschland" },
      ],
      alumniOf: {
        "@type": "CollegeOrUniversity",
        name: "University of Münster",
        url: "https://www.uni-muenster.de/en/",
      },
      knowsAbout: [
        "Full-Stack Web Development",
        "PHP",
        "React",
        "TypeScript",
        "JavaScript",
        "Node.js",
        "Machine Learning",
        "SQL Databases",
        "NoSQL Databases",
        "Web Application Architecture",
      ],
      makesOffer: { "@id": serviceId },
      sameAs: ["https://www.linkedin.com/in/dennis-heinz-a185241a9/"],
    },
    {
      "@type": "ProfessionalService",
      "@id": serviceId,
      name: "Dennis Heinz – Webentwicklung",
      description: serviceDescription,
      url: siteUrl,
      email: "mailto:dennis@dennisheinz.com",
      provider: { "@id": personId },
      founder: { "@id": personId },
      areaServed: [
        { "@type": "City", name: "Rheine" },
        { "@type": "City", name: "Münster" },
        { "@type": "Country", name: "Deutschland" },
      ],
      serviceType: ["Webentwicklung", "Full-Stack-Entwicklung"],
      knowsAbout: [
        "PHP",
        "React",
        "TypeScript",
        "Machine Learning",
        "SQL",
        "NoSQL",
      ],
      sameAs: ["https://www.linkedin.com/in/dennis-heinz-a185241a9/"],
    },
  ],
};

const structuredDataJson = JSON.stringify(structuredData).replace(
  /</g,
  "\\u003c",
);

const ogLocale = "de_DE";
---

<!doctype html>
<html lang={currentLocale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={metaDescription} />

    <link rel="canonical" href={canonical} />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAltText} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAltText} />

    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/feed+xml"
      title={title}
      href="/rss.xml"
    />

    <script is:inline>
      (function () {
        var t = localStorage.getItem("theme");
        if (t) document.documentElement.dataset.theme = t;
      })();
    </script>
    <script
      type="application/ld+json"
      set:html={structuredDataJson}
      is:inline
    />
  </head>
  <body>
    <slot />
  </body>
</html>
