---
import "../styles/global.css";
import { strings, type Locale } from "../i18n/strings";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: "website" | "article";
  lang?: Locale;
}

const {
  title,
  description,
  ogImage,
  ogImageAlt,
  ogType = "website",
  lang = "de",
} = Astro.props;

const t = strings[lang];

const canonical = new URL(Astro.url.pathname, Astro.site);

const siteUrl = Astro.site!.toString().replace(/\/$/, "");
const personId = `${siteUrl}/#person`;
const serviceId = `${siteUrl}/#service`;
const websiteId = `${siteUrl}/#website`;
const ogImageId = `${siteUrl}/og/${lang}.png#image`;

const metaDescription = description ?? t.person.description;
const ogImageUrl = new URL(ogImage ?? `/og/${lang}.png`, Astro.site);
const ogImageAltText =
  ogImageAlt ??
  (lang === "de"
    ? "Dennis Heinz – Softwareentwickler aus dem Münsterland"
    : "Dennis Heinz – software developer from the Münsterland region");
const siteName = "Dennis Heinz";

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": websiteId,
      url: siteUrl,
      name: siteName,
      description: t.person.description,
      inLanguage: lang,
      publisher: { "@id": personId },
    },
    {
      "@type": "ImageObject",
      "@id": ogImageId,
      url: ogImageUrl.toString(),
      contentUrl: ogImageUrl.toString(),
      width: 1200,
      height: 630,
      encodingFormat: "image/png",
      caption: ogImageAltText,
    },
    {
      "@type": "Person",
      "@id": personId,
      name: "Dennis Heinz",
      jobTitle: t.person.jobTitle,
      description: t.person.description,
      url: siteUrl,
      image: { "@id": ogImageId },
      email: "mailto:dennis@dennisheinz.com",
      workLocation: [
        { "@type": "Place", name: "Rheine, Deutschland" },
        { "@type": "Place", name: "Münster, Deutschland" },
      ],
      alumniOf: {
        "@type": "CollegeOrUniversity",
        name: "University of Münster",
        url: "https://www.uni-muenster.de/en/",
      },
      knowsAbout: [
        "Full-Stack Web Development",
        "PHP",
        "React",
        "TypeScript",
        "JavaScript",
        "Node.js",
        "Machine Learning",
        "SQL Databases",
        "NoSQL Databases",
        "Web Application Architecture",
      ],
      makesOffer: { "@id": serviceId },
      sameAs: ["https://www.linkedin.com/in/dennis-heinz-a185241a9/"],
    },
    {
      "@type": "ProfessionalService",
      "@id": serviceId,
      name: t.service.name,
      description: t.service.description,
      url: siteUrl,
      email: "mailto:dennis@dennisheinz.com",
      provider: { "@id": personId },
      founder: { "@id": personId },
      areaServed: [
        { "@type": "City", name: "Rheine" },
        { "@type": "City", name: "Münster" },
        { "@type": "Country", name: "Deutschland" },
      ],
      serviceType: t.service.serviceType,
      knowsAbout: [
        "PHP",
        "React",
        "TypeScript",
        "Machine Learning",
        "SQL",
        "NoSQL",
      ],
      sameAs: ["https://www.linkedin.com/in/dennis-heinz-a185241a9/"],
    },
  ],
};

const structuredDataJson = JSON.stringify(structuredData).replace(
  /</g,
  "\\u003c",
);

const alternates: { hreflang: string; href: string }[] = [
  { hreflang: "de", href: new URL("/de/", Astro.site).toString() },
  { hreflang: "en", href: new URL("/en/", Astro.site).toString() },
  { hreflang: "x-default", href: new URL("/de/", Astro.site).toString() },
];
---

<!doctype html>
<html lang={t.htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={metaDescription} />

    <link rel="canonical" href={canonical} />
    {
      alternates.map((a) => (
        <link rel="alternate" hreflang={a.hreflang} href={a.href} />
      ))
    }

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={t.ogLocale} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAltText} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAltText} />

    <link rel="icon" type="image/svg+xml" href="/logo.svg" />

    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/feed+xml"
      title={title}
      href="/rss.xml"
    />

    <script is:inline>
      (function () {
        var t = localStorage.getItem("theme");
        if (t) document.documentElement.dataset.theme = t;
      })();
    </script>
    <script
      type="application/ld+json"
      set:html={structuredDataJson}
      is:inline
    />
  </head>
  <body>
    <slot />
  </body>
</html>
