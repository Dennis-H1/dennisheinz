---
import { strings, type Locale } from "../i18n/strings";

interface Props {
  lang?: Locale;
}

const { lang = "de" } = Astro.props;
const t = strings[lang];
---

<footer
  class="flex flex-wrap items-center justify-between gap-4 py-10 mt-8 text-[13px] text-muted-foreground"
>
  <span>{t.footer.copyright}</span>
  <div class="flex flex-wrap gap-5">
    <a
      href={t.routes.legal}
      class="hover:text-foreground transition-colors no-underline"
      >{t.footer.impressum}</a
    >
    <a
      href={t.routes.privacy}
      class="hover:text-foreground transition-colors no-underline"
      >{t.footer.datenschutz}</a
    >
    <a
      href="https://github.com/Dennis-H1"
      rel="me"
      class="hover:text-foreground transition-colors no-underline">GitHub</a
    >
    <a
      href="https://www.linkedin.com/in/dennis-heinz-a185241a9/"
      rel="me"
      class="hover:text-foreground transition-colors no-underline">LinkedIn</a
    >
  </div>
</footer>
