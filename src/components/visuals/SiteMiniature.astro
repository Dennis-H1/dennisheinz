---

---

<div
  class="absolute inset-0 overflow-hidden bg-background pointer-events-none select-none"
  aria-hidden="true"
>
  <div class="mini-scale">
    <div class="px-6 max-w-[640px] mx-auto">
      <div class="flex items-center justify-between py-5">
        <span class="text-sm font-medium text-foreground tracking-wider"
          >Dennis Heinz</span
        >
        <div class="flex items-center gap-6 text-[13px] text-muted-foreground">
          <span>Projects</span>
          <span>Writing</span>
          <span>About</span>
          <span>EN</span>
          <span class="inline-block w-4 h-4 rounded-full bg-muted"></span>
        </div>
      </div>
      <div class="pt-8 pb-10">
        <p
          class="text-[11px] font-medium tracking-[0.1em] uppercase text-muted-foreground mb-4"
        >
          Software Developer · Münsterland, DE
        </p>
        <h1
          class="text-4xl font-medium text-foreground-strong leading-[1.05] mb-4"
        >
          Dennis Heinz
        </h1>
        <p class="text-base text-muted-foreground leading-[1.6] max-w-[420px]">
          developer & builder near Münster.
        </p>
        <div
          class="flex gap-5 mt-5 text-[13px] text-muted-foreground underline-offset-[3px]"
        >
          <span class="underline decoration-border">GitHub</span>
          <span class="underline decoration-border">LinkedIn</span>
        </div>
      </div>
      <div class="border-t border-border pt-8 grid grid-cols-2 gap-8">
        <div class="flex flex-col gap-2">
          <div class="flex items-baseline gap-2">
            <span
              class="text-[10px] font-mono text-muted-foreground tabular-nums"
              >01</span
            >
            <span class="text-lg font-medium text-foreground-strong"
              >Lumina</span
            >
          </div>
          <p class="text-[12px] text-muted-foreground leading-snug">
            Spatial canvas for personal intelligence.
          </p>
          <div class="flex gap-1 mt-1">
            <span
              class="px-1.5 py-0.5 text-[9px] font-mono rounded-sm border border-border bg-muted/40 text-muted-foreground"
              >Laravel</span
            >
            <span
              class="px-1.5 py-0.5 text-[9px] font-mono rounded-sm border border-border bg-muted/40 text-muted-foreground"
              >React</span
            >
          </div>
        </div>
        <div
          class="h-24 rounded-md border border-border bg-card relative overflow-hidden"
        >
          <div
            class="absolute inset-0"
            style="background-image: radial-gradient(circle, var(--border) 1px, transparent 1px); background-size: 10px 10px; opacity: 0.6;"
          >
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .mini-scale {
    transform: scale(0.5);
    transform-origin: top left;
    width: 200%;
    height: 200%;
  }
</style>
