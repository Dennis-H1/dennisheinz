---
import { cva, type VariantProps } from "class-variance-authority";
import { cn } from "@/lib/utils";

const labelVariants = cva(
  "text-[11px] font-medium tracking-[0.1em] uppercase text-muted-foreground",
  {
    variants: {
      tone: {
        muted: "text-muted-foreground",
        strong: "text-foreground",
      },
    },
    defaultVariants: {
      tone: "muted",
    },
  },
);

type Tag = "p" | "h2" | "span";

interface Props extends VariantProps<typeof labelVariants> {
  class?: string;
  as?: Tag;
  id?: string;
}

const { tone, class: className, as: Tag = "p", id } = Astro.props;
---

<Tag id={id} class={cn(labelVariants({ tone }), className)}>
  <slot />
</Tag>
