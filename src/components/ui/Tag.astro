---
import { cva, type VariantProps } from "class-variance-authority";
import { cn } from "@/lib/utils";

const tagVariants = cva(
  "inline-flex items-center rounded-sm border border-border bg-muted/40 text-muted-foreground font-mono tracking-tight",
  {
    variants: {
      size: {
        sm: "px-1.5 py-0.5 text-[10px] leading-none",
        md: "px-2 py-1 text-[11px] leading-none",
      },
    },
    defaultVariants: {
      size: "sm",
    },
  },
);

interface Props extends VariantProps<typeof tagVariants> {
  class?: string;
}

const { size, class: className } = Astro.props;
---

<span class={cn(tagVariants({ size }), className)}>
  <slot />
</span>
