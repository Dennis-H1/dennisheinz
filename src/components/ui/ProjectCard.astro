---
import { cva, type VariantProps } from "class-variance-authority";
import { cn } from "@/lib/utils";
import Tag from "./Tag.astro";

const cardVariants = cva(
  "group grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-10 border-t border-border transition-colors hover:bg-accent/40",
  {
    variants: {
      featured: {
        true: "py-12 md:py-16",
        false: "py-10 md:py-12",
      },
    },
    defaultVariants: {
      featured: false,
    },
  },
);

interface Props extends VariantProps<typeof cardVariants> {
  class?: string;
  number: string;
  name: string;
  description: string;
  tags: string[];
  href: string | null;
  hrefLabel?: string;
}

const {
  featured,
  class: className,
  number,
  name,
  description,
  tags,
  href,
  hrefLabel,
} = Astro.props;
---

<article class={cn(cardVariants({ featured }), className)}>
  <div class="flex flex-col gap-4 order-2 md:order-1">
    <div class="flex items-baseline gap-3">
      <span
        class="text-[11px] font-mono tracking-wider text-muted-foreground tabular-nums"
        >{number}</span
      >
      <h3 class="text-xl md:text-2xl font-medium text-foreground-strong">
        {name}
      </h3>
    </div>
    <p class="text-[15px] text-muted-foreground leading-[1.65] max-w-[44ch]">
      {description}
    </p>
    <div class="flex flex-wrap gap-1.5 pt-1">
      {tags.map((tag) => <Tag size="sm">{tag}</Tag>)}
    </div>
    {
      hrefLabel && (
        <div class="pt-2">
          {href ? (
            <a
              href={href}
              class="text-[13px] text-foreground hover:text-primary transition-colors no-underline border-b border-border hover:border-primary pb-0.5"
            >
              {hrefLabel}
            </a>
          ) : (
            <span class="text-[13px] text-muted-foreground italic">
              {hrefLabel}
            </span>
          )}
        </div>
      )
    }
  </div>
  <div class="order-1 md:order-2">
    <div
      class="relative h-48 md:h-full md:min-h-[260px] rounded-md border border-border bg-card overflow-hidden"
    >
      <slot name="visual" />
    </div>
  </div>
</article>
